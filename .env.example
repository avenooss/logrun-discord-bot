# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Warcraft Logs
WARCRAFT_LOGS_CLIENT_ID=your_client_id_here
WARCRAFT_LOGS_CLIENT_SECRET=your_client_secret_here
WARCRAFT_LOGS_REDIRECT_URI=http://localhost:8000/callback

# Battle.net
BATTLENET_API_KEY=your_api_key_here
BATTLENET_REGION=us

# Database
DATABASE_URL=sqlite:///./logrun.db
# For PostgreSQL: postgresql://user:password@localhost:5432/logrun

# Bot Settings
LOG_LEVEL=INFO
REFRESH_INTERVAL=3600
CACHE_TTL=1800
BOT_PREFIX=!

# API
KEEP_ALIVE_PORT=8000
KEEP_ALIVE_HOST=0.0.0.0

# Environment
ENVIRONMENT=development
